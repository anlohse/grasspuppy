{
  "name": "grasspuppy",
  "version": "1.0.0",
  "description": "Offline recreation of grasshopper",
  "main": "dist/main.js",
  "targets": {
    "main": {
      "source": "main.ts",
      "context": "electron-main",
      "distDir": "dist"
    },
    "app": {
      "source": "index.html",
      "context": "browser",
      "distDir": "dist"
    }
  },
  "scripts": {
    "start": "npm run build && npm run execute",
    "build": "npm run clean && parcel build --no-scope-hoist",
    "dev": "parcel index.html --dist-dir dist",
    "execute": "electron .",
    "clean": "rimraf dist .parcel-cache"
  },
  "author": "Alan N. Lohse",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/bootstrap": "^4.6.2",
    "@types/jquery": "^3.5.1",
    "@types/node": "^18.15.0",
    "electron": "^23.1.1",
    "parcel": "^2.13.3",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "monaco-editor": "^0.55.1"
  }
}
