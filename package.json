{
  "name": "grasspuppy",
  "version": "1.0.0",
  "description": "Offline recreation of grasshopper",
  "main": "dist/main.js",
  "targets": {
    "main": {
      "source": "main.ts",
      "context": "electron-main",
      "distDir": "dist"
    },
    "app": {
      "source": "index.html",
      "context": "browser",
      "distDir": "dist"
    }
  },
  "scripts": {
    "start": "npm run build && npm run execute",
    "build": "npm run clean && parcel build --no-scope-hoist",
    "dev": "parcel index.html --dist-dir dist",
    "execute": "electron .",
    "clean": "rimraf dist .parcel-cache",
    "package:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "package:linux": "npm run build && electron-builder --linux AppImage"
  },
  "author": "Alan N. Lohse",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/bootstrap": "^4.6.2",
    "@types/jquery": "^3.5.1",
    "@types/node": "^18.15.0",
    "cross-env": "^7.0.3",
    "electron": "^23.1.1",
    "electron-builder": "^24.9.0",
    "parcel": "^2.13.3",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.alannlohse.grasspuppy",
    "productName": "Grasspuppy",
    "files": [
      "dist/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "grasspuppy-${version}-windows.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "grasspuppy-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "monaco-editor": "^0.55.1"
  }
}
